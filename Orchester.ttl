@prefix ns1: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<https://kiran.materials-data.space/orchester> a owl:Ontology .

<https://w3id.org/dsms/orchester/AngleToRD> a owl:Class ;
    rdfs:label "AngleToRD" ;
    ns1:contributor "Lukas Morand" ;
    ns1:description "Angle to rolling direction" ;
    ns1:identifier "AngleToRD" .

<https://w3id.org/dsms/orchester/BandContrast> a owl:Class ;
    rdfs:label "Band Contrast" ;
    ns1:contributor "Lukas Morand" ;
    ns1:description "Measure of sharpness and intensity contrast of Kikuchi bands in the diffraction pattern; higher values indicate better pattern quality" ;
    ns1:identifier "BandContrast" ;
    ns1:source "AI generated" ;
    rdfs:comment "Generated by Claude Sonnet" .

<https://w3id.org/dsms/orchester/CrystalPhase> a owl:Class ;
    rdfs:label "Crystal Phase" ;
    ns1:contributor "Lukas Morand" ;
    ns1:description "Integer identifier for the crystallographic phase or material at the measurement point (e.g., 1=austenite, 2=ferrite)" ;
    ns1:identifier "CrystalPhase" ;
    ns1:source "AI generated" ;
    rdfs:comment "Generated by Claude Sonnet" .

<https://w3id.org/dsms/orchester/DetectedBands> a owl:Class ;
    rdfs:label "Detected Bands" ;
    ns1:contributor "Lukas Morand" ;
    ns1:description "Number of Kikuchi bands successfully identified and indexed in the electron backscatter diffraction pattern" ;
    ns1:identifier "DetectedBands" ;
    ns1:source "AI generated" ;
    rdfs:comment "Generated by Claude Sonnet" .

<https://w3id.org/dsms/orchester/EBSDMeasurement> a owl:Class ;
    rdfs:label "EBSD Measurement" ;
    ns1:contributor "Lukas Morand" ;
    ns1:description "Concept to tag EBSD measurements" ;
    ns1:identifier "EBSDMeasurement" .

<https://w3id.org/dsms/orchester/EulerAnglePhi> rdfs:label "Euler Angle Phi" ;
    ns1:description "Second Euler angle (Φ) in Bunge convention, representing rotation about the X'-axis (range: 0-180°)" ;
    ns1:identifier "EulerAnglePhi" .

<https://w3id.org/dsms/orchester/EulerAnglePhi1> a owl:Class ;
    rdfs:label "Euler Angle phi1" ;
    ns1:contributor "Lukas Morand" ;
    ns1:description "First Euler angle (φ₁) in Bunge convention, representing rotation about the Z-axis (range: 0-360°)" ;
    ns1:identifier "EulerAnglePhi1" ;
    ns1:source "AI generated" ;
    rdfs:comment "Generated by Claude Sonnet" .

<https://w3id.org/dsms/orchester/EulerAnglePhi2> a owl:Class ;
    rdfs:label "Euler Angle phi2" ;
    ns1:contributor "Lukas Morand" ;
    ns1:description "Third Euler angle (φ₂) in Bunge convention, representing rotation about the Z''-axis (range: 0-360°)" ;
    ns1:identifier "EulerAnglePhi2" ;
    ns1:source "AI generated" ;
    rdfs:comment "Generated by Claude Sonnet" .

<https://w3id.org/dsms/orchester/IndexingError> a owl:Class ;
    rdfs:label "Indexing Error" ;
    ns1:contributor "Lukas Morand" ;
    ns1:description "Error flag or reliability indicator for the pattern indexing process (0 = successful indexing, higher values = problematic indexing)" ;
    ns1:identifier "IndexingError" ;
    ns1:source "AI generated" ;
    rdfs:comment "Generated by Claude Sonnet" .

<https://w3id.org/dsms/orchester/MeanAngularDeviation> a owl:Class ;
    rdfs:label "Mean Angular Deviation" ;
    ns1:contributor "Lukas Morand" ;
    ns1:description "Average angular deviation between detected and theoretical Kikuchi bands; lower values indicate better pattern fit, typically measured in degrees" ;
    ns1:identifier "MeanAngularDeviation" ;
    ns1:source "AI generated" ;
    rdfs:comment "Generated by Claude Sonnet" .

<https://w3id.org/dsms/orchester/MeasurementDirection> a owl:Class ;
    rdfs:label "Measurement Direction" ;
    ns1:contributor "Lukas Morand" ;
    ns1:description "The scanning direction or acquisition mode of the EBSD scan (e.g., horizontal, vertical, or specific pattern)" ;
    ns1:identifier "MeasurementDirection" ;
    ns1:source "AI generated" ;
    rdfs:comment "Generated by Claude Sonnet" .

<https://w3id.org/dsms/orchester/OrchesterBaseTerm1> a owl:Class ;
    rdfs:label "Orchester Base Term1" ;
    ns1:description "wrwr" ;
    ns1:identifier "OrchesterBaseTerm1" .

<https://w3id.org/dsms/orchester/QualityRating> a owl:Class ;
    rdfs:label "Quality Rating" ;
    ns1:contributor "Lukas Morand" ;
    ns1:description "Overall quality rating or metric for the electron backscatter diffraction pattern at each measurement point" ;
    ns1:identifier "QualityRating" ;
    ns1:source "AI generated" ;
    rdfs:comment "Generated by Claude Sonnet" .

<https://w3id.org/dsms/orchester/Test1> a owl:Class ;
    rdfs:label "Test1 updated" ;
    ns1:description "Test1 updated123" ;
    ns1:identifier "Test1" ;
    rdfs:comment "fefefe" ;
    rdfs:subClassOf <https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Cobalt>,
        <https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#FlatTensileTestSpecimen>,
        <https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#YoungsModulus> ;
    owl:equivalentClass <https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#ArtificialAgingTemperature>,
        <https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#CrackPath>,
        <https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#Thermocouples>,
        <https://www.iwm.fraunhofer.de/ontologies/bwmd-ontology#YoungsModulus> .

<https://w3id.org/dsms/orchester/Test2> a owl:ObjectProperty ;
    rdfs:label "Test2" ;
    ns1:description "eqr3r" ;
    ns1:identifier "Test2" .

<https://w3id.org/dsms/orchester/XCoordinate> a owl:Class ;
    rdfs:label "X Coordinate" ;
    ns1:contributor "Lukas Morand" ;
    ns1:description "Horizontal position of the measurement point in the scan grid, typically measured in micrometers from the origin" ;
    ns1:identifier "XCoordinate" ;
    ns1:source "AI generated" ;
    rdfs:comment "Generated by Claude Sonnet" .

<https://w3id.org/dsms/orchester/YCoordinate> a owl:Class ;
    rdfs:label "Y Coordinate" ;
    ns1:contributor "Lukas Morand" ;
    ns1:description "Vertical position of the measurement point in the scan grid, typically measured in micrometers from the origin" ;
    ns1:identifier "YCoordinate" ;
    ns1:source "AI generated" ;
    rdfs:comment "Generated by Claude Sonnet" .

<https://w3id.org/dsms/orchester/magnet-predictor/Composition> a owl:Class ;
    rdfs:label "Composition" ;
    ns1:contributor "Manuel Enns" ;
    ns1:description "Chemical Formula of the compound1" ;
    ns1:identifier "Composition" .

<https://w3id.org/dsms/orchester/magnet-predictor/FormationEnergy> a owl:Class ;
    rdfs:label "Formation Energy" ;
    ns1:contributor "Matthias Büschelberger" ;
    ns1:description "The rnergy change associated with the formation of a compound from its elemental constituents in their standard states. This class encapsulates the thermodynamic properties relevant to the formation process, including the standard formation enthalpy and Gibbs free energy of formation. The maximum energy product BHmax [kJ/m3] is determined by the hysteresis curve as the maximum of BH in the second quadrant of the curve (saturation demagnetization)." ;
    ns1:identifier "FormationEnergy" ;
    ns1:source "https://inside.fraunhofer.de/materialmodellierung-2/" .

<https://w3id.org/dsms/orchester/magnet-predictor/HasProcessParameters> a owl:DatatypeProperty ;
    rdfs:label "has process parameters" ;
    ns1:identifier "HasProcessParameters" .

<https://w3id.org/dsms/orchester/magnet-predictor/IntrinsicCoercivity> a owl:Class ;
    rdfs:label "Intrinsic coercivity" ;
    ns1:description "It is the magnetic field strength required to demagnetize the magnet (reduce magnetization to zero)." ;
    ns1:identifier "IntrinsicCoercivity" .

<https://w3id.org/dsms/orchester/magnet-predictor/MachineLearning> a owl:Class ;
    rdfs:label "Machine Learning" ;
    ns1:contributor "Matthias Büschelberger" ;
    ns1:description "Machine learning (ML) is a field of study in artificial intelligence concerned with the development and study of statistical algorithms that can learn from data and generalize to unseen data, and thus perform tasks without explicit instructions. Within a subdiscipline in machine learning, advances in the field of deep learning have allowed neural networks, a class of statistical algorithms, to surpass many previous machine learning approaches in performance." ;
    ns1:identifier "MachineLearning" ;
    ns1:source "https://en.wikipedia.org/wiki/Machine_learning" .

<https://w3id.org/dsms/orchester/magnet-predictor/MagnetProductionProcess> a owl:Class ;
    rdfs:label "Magnet production process" ;
    ns1:identifier "MagnetProductionProcess" .

<https://w3id.org/dsms/orchester/magnet-predictor/MagneticRemanence> a owl:Class ;
    rdfs:label "Magnetic Remanence" ;
    ns1:contributor "Matthias Büschelberger" ;
    ns1:description "The magnetic remanence Mr [T] describes the maximal magnetization of your sample without an applied magnetic field." ;
    ns1:identifier "MagneticRemanence" ;
    ns1:source "https://inside.fraunhofer.de/materialmodellierung-2/" .

<https://w3id.org/dsms/orchester/magnet-predictor/MaximumEnergyProduct> a owl:Class ;
    rdfs:label "MaximumEnergyProduct" ;
    ns1:contributor "Manuel Enns" ;
    ns1:description "The maximum energy product BHmax [kJ/m3] is determined by the hysteresis curve as the maximum of BH in the second quadrant of the curve (saturation demagnetization)." ;
    ns1:identifier "MaximumEnergyProduct" ;
    ns1:source "https://en.wikipedia.org/wiki/Maximum_energy_product" .

<https://w3id.org/dsms/orchester/magnet-predictor/Performance> a owl:Class ;
    rdfs:label "Performance" ;
    ns1:identifier "Performance" .

<https://w3id.org/dsms/orchester/magnet-predictor/RawMaterialCarbonFootprint> a owl:Class ;
    rdfs:label "RawMaterialCarbonFootprint" ;
    ns1:contributor "Manuel Enns" ;
    ns1:description "kg CO2-equivalent of all raw elements added up. Data taken from LCA paper (see source)." ;
    ns1:identifier "RawMaterialCarbonFootprint" ;
    ns1:source "https://doi.org/10.1371/journal.pone.0101298" .

<https://w3id.org/dsms/orchester/magnet-predictor/RawMaterialPrice> a owl:Class ;
    rdfs:label "https://doi.org/10.1371/journal.pone.0101298" ;
    ns1:contributor "Manuel Enns" ;
    ns1:description "Price of all raw elements added up. Prices from 10/2024. This is only a rough estimate to enable a qualitative comparison and should not be seen as a current exact price estimate" ;
    ns1:identifier "RawMaterialPrice" .

<https://w3id.org/dsms/orchester/magnet-predictor/Squareness> a owl:Class ;
    rdfs:label "Squareness" ;
    ns1:description "Squareness describes the shape of the demagnetization curve in the second quadrant of the hysteresis loop." ;
    ns1:identifier "Squareness" .

<https://w3id.org/dsms/orchester/magnet-predictor/ThermalConditioningHeaterTemperature> a owl:Class ;
    rdfs:label "Thermal conditioning heating temperature" ;
    ns1:identifier "ThermalConditioningHeaterTemperature" .

<https://w3id.org/dsms/orchester/magnet-predictor/Time> a owl:Class ;
    rdfs:label "Time" ;
    ns1:identifier "Time" .

<https://w3id.org/dsms/orchester/magnet-predictor/UniaxialAnisotropy> a owl:Class ;
    rdfs:label "Uniaxial Anisotropy" ;
    ns1:contributor "Matthias Büschelberger" ;
    ns1:description "The uniaxial anisotropy field HA [T] is the maximal theoretical limit of an external magnetic field needed to reverse the magnetization of your sample. Typical real coercitivities HC [T] are below 0.2 HA." ;
    ns1:identifier "UniaxialAnisotropy" ;
    ns1:source "https://inside.fraunhofer.de/materialmodellierung-2/" .

<https://w3id.org/dsms/orchester/magnet-predictor/testRelationOrchester> a owl:ObjectProperty ;
    rdfs:label "testRelationOrchester" ;
    ns1:description "Test relOrchester" .

<https://w3id.org/dsms/orchester/magnet-predictor/testRelationOrchester2> a owl:Class ;
    rdfs:label "test relation orchester2" ;
    ns1:description "200.0" ;
