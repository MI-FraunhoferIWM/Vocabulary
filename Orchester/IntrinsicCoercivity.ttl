@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<https://w3id.org/dsms/orchester/magnet-predictor/IntrinsicCoercivity> a owl:Class ;
    rdfs:label "Intrinsic coercivity" ;
    dcterms:description "It is the magnetic field strength required to demagnetize the magnet (reduce magnetization to zero)." ;
    dcterms:identifier "IntrinsicCoercivity" .

