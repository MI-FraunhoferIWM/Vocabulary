<https://w3id.org/dsms/orchester/magnet-predictor/MaximumEnergyProduct> a owl:Class ;
    rdfs:label "MaximumEnergyProduct" ;
    dcterms:contributor "Manuel Enns" ;
    dcterms:description "The maximum energy product BHmax [kJ/m3] is determined by the hysteresis curve as the maximum of BH in the second quadrant of the curve (saturation demagnetization)." ;
