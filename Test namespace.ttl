@prefix ns1: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<https://vocabulary.materials-data.space/test-namespace> a owl:Ontology .

<https://w3id.org/dsms/test-namespace/AngleToRD> a owl:Class ;
    rdfs:label "AngleToRD" ;
    ns1:contributor "Lukas Morand" ;
    ns1:description "Angle to rolling direction" ;
    ns1:identifier "AngleToRD" .

<https://w3id.org/dsms/test-namespace/BandContrast> a owl:Class ;
    rdfs:label "Band Contrast" ;
    ns1:contributor "Lukas Morand" ;
    ns1:description "Measure of sharpness and intensity contrast of Kikuchi bands in the diffraction pattern; higher values indicate better pattern quality" ;
    ns1:identifier "BandContrast" ;
    ns1:source "AI generated" ;
    rdfs:comment "Generated by Claude Sonnet" .

<https://w3id.org/dsms/test-namespace/CrystalPhase> a owl:Class ;
    rdfs:label "Crystal Phase" ;
    ns1:contributor "Lukas Morand" ;
    ns1:description "Integer identifier for the crystallographic phase or material at the measurement point (e.g., 1=austenite, 2=ferrite)" ;
    ns1:identifier "CrystalPhase" ;
    ns1:source "AI generated" ;
    rdfs:comment "Generated by Claude Sonnet" .

<https://w3id.org/dsms/test-namespace/DetectedBands> a owl:Class ;
    rdfs:label "Detected Bands" ;
    ns1:contributor "Lukas Morand" ;
    ns1:description "Number of Kikuchi bands successfully identified and indexed in the electron backscatter diffraction pattern" ;
    ns1:identifier "DetectedBands" ;
    ns1:source "AI generated" ;
    rdfs:comment "Generated by Claude Sonnet" .

<https://w3id.org/dsms/test-namespace/EBSDMeasurement> a owl:Class ;
    rdfs:label "EBSD Measurement" ;
    ns1:contributor "Lukas Morand" ;
    ns1:description "Concept to tag EBSD measurements" ;
    ns1:identifier "EBSDMeasurement" .

<https://w3id.org/dsms/test-namespace/EulerAnglePhi> rdfs:label "Euler Angle Phi" ;
    ns1:description "Second Euler angle (Φ) in Bunge convention, representing rotation about the X'-axis (range: 0-180°)" ;
    ns1:identifier "EulerAnglePhi" .

<https://w3id.org/dsms/test-namespace/EulerAnglePhi1> a owl:Class ;
    rdfs:label "Euler Angle phi1" ;
    ns1:contributor "Lukas Morand" ;
    ns1:description "First Euler angle (φ₁) in Bunge convention, representing rotation about the Z-axis (range: 0-360°)" ;
    ns1:identifier "EulerAnglePhi1" ;
    ns1:source "AI generated" ;
    rdfs:comment "Generated by Claude Sonnet" .

<https://w3id.org/dsms/test-namespace/EulerAnglePhi2> a owl:Class ;
    rdfs:label "Euler Angle phi2" ;
    ns1:contributor "Lukas Morand" ;
    ns1:description "Third Euler angle (φ₂) in Bunge convention, representing rotation about the Z''-axis (range: 0-360°)" ;
    ns1:identifier "EulerAnglePhi2" ;
    ns1:source "AI generated" ;
    rdfs:comment "Generated by Claude Sonnet" .

<https://w3id.org/dsms/test-namespace/IndexingError> a owl:Class ;
    rdfs:label "Indexing Error" ;
    ns1:contributor "Lukas Morand" ;
    ns1:description "Error flag or reliability indicator for the pattern indexing process (0 = successful indexing, higher values = problematic indexing)" ;
    ns1:identifier "IndexingError" ;
    ns1:source "AI generated" ;
    rdfs:comment "Generated by Claude Sonnet" .

<https://w3id.org/dsms/test-namespace/MeanAngularDeviation> a owl:Class ;
    rdfs:label "Mean Angular Deviation" ;
    ns1:contributor "Lukas Morand" ;
    ns1:description "Average angular deviation between detected and theoretical Kikuchi bands; lower values indicate better pattern fit, typically measured in degrees" ;
    ns1:identifier "MeanAngularDeviation" ;
    ns1:source "AI generated" ;
    rdfs:comment "Generated by Claude Sonnet" .

<https://w3id.org/dsms/test-namespace/MeasurementDirection> a owl:Class ;
    rdfs:label "Measurement Direction" ;
    ns1:contributor "Lukas Morand" ;
    ns1:description "The scanning direction or acquisition mode of the EBSD scan (e.g., horizontal, vertical, or specific pattern)" ;
    ns1:identifier "MeasurementDirection" ;
    ns1:source "AI generated" ;
    rdfs:comment "Generated by Claude Sonnet" .

<https://w3id.org/dsms/test-namespace/QualityRating> a owl:Class ;
    rdfs:label "Quality Rating" ;
    ns1:contributor "Lukas Morand" ;
    ns1:description "Overall quality rating or metric for the electron backscatter diffraction pattern at each measurement point" ;
    ns1:identifier "QualityRating" ;
    ns1:source "AI generated" ;
    rdfs:comment "Generated by Claude Sonnet" .

<https://w3id.org/dsms/test-namespace/XCoordinate> a owl:Class ;
    rdfs:label "X Coordinate" ;
    ns1:contributor "Lukas Morand" ;
    ns1:description "Horizontal position of the measurement point in the scan grid, typically measured in micrometers from the origin" ;
    ns1:identifier "XCoordinate" ;
    ns1:source "AI generated" ;
    rdfs:comment "Generated by Claude Sonnet" .

<https://w3id.org/dsms/test-namespace/YCoordinate> a owl:Class ;
    rdfs:label "Y Coordinate" ;
    ns1:contributor "Lukas Morand" ;
    ns1:description "Vertical position of the measurement point in the scan grid, typically measured in micrometers from the origin" ;
    ns1:identifier "YCoordinate" ;
    ns1:source "AI generated" ;
    rdfs:comment "Generated by Claude Sonnet" .

