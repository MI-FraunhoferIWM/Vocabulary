@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<https://w3id.org/dsms/orchester/Expert> a owl:Class ;
    rdfs:label "Expert" ;
    dcterms:description "A person with domain expertise in a scientific or engineering discipline, such as a researcher, engineer, or technician, who can act as an operator of processes or as a subject-matter expert for materials and measurement devices." ;
    dcterms:identifier "Expert" ;
    dcterms:source "Manual" ;
    rdfs:comment "Distinct from the generic Person class in that an Expert is associated with specific domain knowledge, operational competences, and professional affiliations. Typical roles include principal investigator, process operator, materials specialist, and measurement device operator." .

